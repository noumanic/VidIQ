# ─────────────────────────────────────────────────────────────────────────
# LLM PROVIDER
#   Primary provider — the runtime auto-falls back to any other provider
#   whose key is also configured (gemini → groq → openai).
# ─────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini                              # gemini | groq | openai | stub

# Option A — Google Gemini (FREE tier, multimodal)
#   Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_VISION_MODEL=gemini-flash-latest

# Option B — Groq (FREE tier, fastest text inference, recommended fallback)
#   Get a key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Option C — OpenAI (paid)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────────────────
# TRANSCRIPTION
#   YouTube videos use the free YouTube transcript API automatically.
#   For non-YouTube or transcript-less videos:
# ─────────────────────────────────────────────────────────────────────────
TRANSCRIPTION_PROVIDER=local                     # local | openai | none
TRANSCRIPTION_MODEL=whisper-1                    # only used if provider=openai
WHISPER_LOCAL_MODEL=tiny                         # tiny | base | small | medium
WHISPER_LOCAL_DEVICE=cpu                         # cpu | cuda
WHISPER_LOCAL_COMPUTE=int8                       # int8 | float16

# ─────────────────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./vidiq.db      # postgresql+asyncpg://… in prod
MEDIA_DIR=./media
CORS_ORIGINS=http://localhost:3000
