# Where the FastAPI backend is reachable from the browser AND the Next.js server
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public canonical hostname — used by sitemap.xml, robots.txt, JSON-LD,
# OpenGraph URLs and per-page <link rel="canonical">. Required on Vercel
# Production so search engines index the right host (not the deployment URL).
NEXT_PUBLIC_SITE_URL=https://vidiq-two.vercel.app

# Search-engine site verification — paste the *content* value from each
# console's HTML-tag verification method. All optional; meta tags only emit
# when the var is set.
#   Google Search Console:  https://search.google.com/search-console
#     Add property → URL prefix → Verify with HTML tag → copy content="..."
#   Bing Webmaster:         https://www.bing.com/webmasters
#     Add site → Verify with HTML meta tag → copy content="..."
#   Yandex Webmaster:       https://webmaster.yandex.com (only if targeting RU/CIS)
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
